#!/bin/sh
# Birdsong kiosk autostart for the Raspberry Pi OS labwc (Wayland) desktop.
#
# Install on the Pi:
#   cp kiosk/labwc-autostart ~/.config/labwc/autostart
#   (then reboot, or restart the labwc session)
#
# Boots straight into a full-screen Chromium showing the bird display. The Pi
# must autologin to the desktop, and birdsong.service must be running (it serves
# localhost:8000). Removing ~/.config/labwc/autostart restores the normal desktop.

export DISPLAY=:0

# Wait for the local web server before launching the browser (avoids a race at boot).
for i in $(seq 1 60); do
  curl -sf http://localhost:8000/state >/dev/null 2>&1 && break
  sleep 1
done

# Notes on the flags:
#   --ozone-platform=x11   run via Xwayland. Native Wayland left dialogs invisible.
#   --password-store=basic skips the gnome-keyring "Choose password" dialog that
#                          otherwise blocks Chromium behind a blank white screen.
#   lwrespawn              restarts Chromium automatically if it ever exits.
/usr/bin/lwrespawn /usr/bin/chromium \
  --ozone-platform=x11 \
  --kiosk \
  --password-store=basic \
  --no-first-run \
  --noerrdialogs \
  --disable-infobars \
  --disable-session-crashed-bubble \
  --check-for-update-interval=31536000 \
  http://localhost:8000 &
