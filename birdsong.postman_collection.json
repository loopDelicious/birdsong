{
	"info": {
		"_postman_id": "c9a11a91-3969-47f3-a33b-81b8c71f2770",
		"name": "Birdsong",
		"description": "Endpoints for the [Birdsong detector](https://github.com/loopDelicious/birdsong/tree/main) + display app (app.py). Set the `base_url` collection variable to your Pi, e.g. http://birdpi.local:8000",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "1215211"
	},
	"item": [
		{
			"name": "Read",
			"item": [
				{
					"name": "State (live display feed)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/state",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"state"
							]
						},
						"description": "Current bird(s), today's tally, clock, and config. Polled by the kiosk/TFT every 1.5s."
					},
					"response": []
				},
				{
					"name": "Today",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/today",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"today"
							]
						},
						"description": "Today's species with counts, first/last heard, and peak confidence (from the SQLite log)."
					},
					"response": []
				},
				{
					"name": "History (rolling window)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var template = `",
									"<canvas id=\"detectionsChart\" height=\"75\"></canvas>",
									"",
									"<script src=\"https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js\"></script>",
									"<script src=\"https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.5.0/Chart.min.js\"></script> ",
									"",
									"",
									"<script>",
									"    var ctx = document.getElementById(\"detectionsChart\");",
									"",
									"    var detectionsChart = new Chart(ctx, {",
									"        type: \"line\",",
									"        data: {",
									"            labels: [],",
									"            datasets: [{",
									"                label: 'Detections',",
									"                data: [],",
									"                borderColor: 'rgba(75, 192, 192, 1)',",
									"                borderWidth: 2,",
									"                fill: false",
									"            }]",
									"        },",
									"        options: {",
									"            title: {",
									"                display: true,",
									"                text: 'Detections Over Time'",
									"            },",
									"            scales: {",
									"                xAxes: [{",
									"                    type: 'time',",
									"                    time: {",
									"                        unit: 'day'",
									"                    },",
									"                    scaleLabel: {",
									"                        display: true,",
									"                        labelString: 'Date'",
									"                    }",
									"                }],",
									"                yAxes: [{",
									"                    scaleLabel: {",
									"                        display: true,",
									"                        labelString: 'Number of Detections'",
									"                    }",
									"                }]",
									"            }",
									"        }",
									"    });",
									"",
									"    pm.getData(function (err, value) {",
									"        detectionsChart.data.labels = value.response.daily.reverse().map(entry => new Date(entry.date));",
									"        detectionsChart.data.datasets[0].data = value.response.daily.reverse().map(entry => entry.detections);",
									"        detectionsChart.update();",
									"    });",
									"",
									"</script>`;",
									"  ",
									"function constructVisualizerPayload() {",
									"    var res = pm.response.json();",
									"    ",
									"    return {response: res};",
									"}",
									"",
									"pm.visualizer.set(template, constructVisualizerPayload());"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/history?days=7",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"history"
							],
							"query": [
								{
									"key": "days",
									"value": "7",
									"description": "1-365, default 14"
								}
							]
						},
						"description": "Per-day totals, daily breakdown, and top species over the window."
					},
					"response": []
				},
				{
					"name": "History (specific day)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/history?date=2026-06-21",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"history"
							],
							"query": [
								{
									"key": "date",
									"value": "2026-06-21",
									"description": "YYYY-MM-DD; drills into one day"
								}
							]
						},
						"description": "One day's species breakdown (same shape as /today)."
					},
					"response": []
				},
				{
					"name": "GPS (current fix)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/gps",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"gps"
							]
						},
						"description": "Current GPS fix from the USB stick: {fix, lat, lon, speed (m/s), heading, sats, hdop, ts, device}. fix=false means no current position (no stick / no satellites / just started)."
					},
					"response": []
				},
				{
					"name": "Detections (with GPS)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/detections?from=2026-06-14&to=2026-06-21",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"detections"
							],
							"query": [
								{
									"key": "from",
									"value": "2026-06-14",
									"description": "YYYY-MM-DD inclusive (default: 14 days back from `to`)"
								},
								{
									"key": "to",
									"value": "2026-06-21",
									"description": "YYYY-MM-DD inclusive (default: today)"
								},
								{
									"key": "species",
									"value": "Turdus migratorius",
									"description": "Optional scientific name filter",
									"disabled": true
								},
								{
									"key": "all",
									"value": "1",
									"description": "Include rows without GPS coords (default: only rows with lat/lon)",
									"disabled": true
								},
								{
									"key": "limit",
									"value": "5000",
									"description": "Max rows, 1-20000 (default 5000)",
									"disabled": true
								}
							]
						},
						"description": "Historical detections within a date range. By default only rows with GPS coords are returned (so the map page can plot them directly). Pass `all=1` to include un-geocoded rows."
					},
					"response": []
				},
				{
					"name": "Track (GPS trail)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/track?from=2026-06-14&to=2026-06-21",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"track"
							],
							"query": [
								{
									"key": "from",
									"value": "2026-06-14",
									"description": "YYYY-MM-DD inclusive"
								},
								{
									"key": "to",
									"value": "2026-06-21",
									"description": "YYYY-MM-DD inclusive"
								},
								{
									"key": "limit",
									"value": "20000",
									"description": "Max points, 1-100000",
									"disabled": true
								}
							]
						},
						"description": "GPS track points (continuous bike-ride trail) ordered by time. Points are written distance-thresholded (~8m or 30s), so a stationary install produces near-zero rows."
					},
					"response": []
				},
				{
					"name": "Map page (HTML)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/map",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"map"
							]
						},
						"description": "The Leaflet map view: clustered markers for detections + the ride trail, with species and date-range filters. Open in a browser; not really a JSON API."
					},
					"response": []
				}
			]
		},
		{
			"name": "Control (write)",
			"item": [
				{
					"name": "Set min confidence",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"min_conf\": 0.6\n}"
						},
						"url": {
							"raw": "{{base_url}}/control",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"control"
							]
						},
						"description": "Set the detection confidence threshold (0.10-0.95)."
					},
					"response": []
				},
				{
					"name": "Toggle location filter",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"use_location\": true\n}"
						},
						"url": {
							"raw": "{{base_url}}/control",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"control"
							]
						},
						"description": "Turn the local (SF) species filter on/off. Turning on prunes non-local birds from the display."
					},
					"response": []
				},
				{
					"name": "Clear screen",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{}"
						},
						"url": {
							"raw": "{{base_url}}/clear",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"clear"
							]
						},
						"description": "Clear the currently-displayed birds (resets to Listening)."
					},
					"response": []
				},
				{
					"name": "Demo (inject birds for screenshots)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"species\": [\n    { \"common\": \"American Robin\", \"scientific\": \"Turdus migratorius\", \"confidence\": 0.82 },\n    { \"common\": \"House Finch\", \"scientific\": \"Haemorhous mexicanus\", \"confidence\": 0.64 }\n  ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/demo",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"demo"
							]
						},
						"description": "Inject species into the live display (does not write to the log). Handy for screenshots."
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://birdpi.local:8000"
		}
	]
}
